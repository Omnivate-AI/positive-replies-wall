{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "noEmit": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"]
  },
  "include": ["trigger/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts", "trigger.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist", ".next", ".trigger"]
}
